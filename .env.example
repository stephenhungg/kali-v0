# env vars contract for kali-v0.
# copy to .env.local and fill in real values. NEVER commit .env or .env.local.

# ─── agent runtime ───────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# optional: override the model used for the orchestrator agent
KALI_AGENT_MODEL=claude-sonnet-4-6
# optional: override the cheap routing model
KALI_ROUTER_MODEL=claude-haiku-4-5-20251001

# ─── embeddings ──────────────────────────────────────────────────────────

VOYAGE_API_KEY=
# fallback if voyage is down or not configured
OPENAI_API_KEY=

# ─── database ────────────────────────────────────────────────────────────

# Neon (or any postgres connection string with pgvector available)
DATABASE_URL=

# ─── auth (clerk) ────────────────────────────────────────────────────────

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── solana payouts (devnet for v1 demo) ─────────────────────────────────

SOLANA_RPC_URL=https://api.devnet.solana.com
# path to the keypair json that funds the demo treasury
SOLANA_PAYOUT_KEYPAIR_PATH=
SOLANA_EXPLORER_BASE=https://explorer.solana.com

# ─── observability (optional) ────────────────────────────────────────────

AXIOM_TOKEN=
SENTRY_DSN=

# ─── feature flags / demo mode ───────────────────────────────────────────

# when true, skip-login lands directly on the Rivertown demo tenant
KALI_DEMO_MODE=false
# show the dev source-pulse panel even when no agent is running
KALI_DEV_SOURCE_PULSE=false
