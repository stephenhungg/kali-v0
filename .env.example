# env vars contract for kali-v0.
# copy to .env.local and fill in real values. NEVER commit .env or .env.local.

# ─── agent runtime ───────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
# optional: override the model used for the orchestrator agent
KALI_AGENT_MODEL=claude-sonnet-4-6
# optional: override the cheap routing model
KALI_ROUTER_MODEL=claude-haiku-4-5-20251001

# ─── embeddings ──────────────────────────────────────────────────────────

VOYAGE_API_KEY=
# fallback if voyage is down or not configured
OPENAI_API_KEY=

# ─── database ────────────────────────────────────────────────────────────

# Neon (or any postgres connection string with pgvector available)
DATABASE_URL=

# ─── auth (clerk) ────────────────────────────────────────────────────────

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── solana payouts (devnet for v1 demo) ─────────────────────────────────

SOLANA_RPC_URL=https://api.devnet.solana.com
# path to the keypair json that funds the demo treasury
SOLANA_PAYOUT_KEYPAIR_PATH=
SOLANA_EXPLORER_BASE=https://explorer.solana.com

# ─── observability (optional) ────────────────────────────────────────────

AXIOM_TOKEN=
SENTRY_DSN=

# ─── x402 agent donations (devnet for v1) ────────────────────────────────

# which network the public x402 endpoint settles on
KALI_X402_NETWORK=solana-devnet
# facilitator: payai | coinbase | self-hosted
KALI_X402_FACILITATOR=self-hosted
PAYAI_API_KEY=
COINBASE_CDP_KEY=
# fail-closed OFAC screening before settlement (true | false)
KALI_TRM_REQUIRED=false
TRM_LABS_API_KEY=

# USDC mints (do not change unless cluster changes)
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── privy server wallets (per-tenant treasury) ──────────────────────────

PRIVY_APP_ID=
PRIVY_APP_SECRET=
# falls back to KALI_SOLANA_DEVNET_SECRET_KEY when Privy is not configured
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── inngest (recurring x402, indexer, graduation watcher) ───────────────

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# inngest dev server URL (only used in dev)
INNGEST_DEV_SERVER_URL=http://localhost:8288

# ─── public hosts (subdomain routing) ────────────────────────────────────

KALI_PAY_HOST=pay.kalilabs.ai
KALI_COIN_HOST=coin.kalilabs.ai
# tax-receipt URL signing key (ed25519 base58 or hex); generate with:
#   openssl rand -hex 32
KALI_RECEIPT_SIGNING_KEY=

# ─── feature flags / demo mode ───────────────────────────────────────────

# when true, skip-login lands directly on the Rivertown demo tenant
KALI_DEMO_MODE=false
# show the dev source-pulse panel even when no agent is running
KALI_DEV_SOURCE_PULSE=false
# pre-funded devnet keypair for x402 facilitator + cause-coin deploy
# (base58 secret OR JSON array of bytes)
KALI_SOLANA_DEVNET_SECRET_KEY=
